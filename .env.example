# Connection to your Postgres instance. If both containers share a Docker
# network, use the Postgres container name as the host.
DATABASE_URL="postgresql://famdash:CHANGE_ME@postgres:5432/familydashboard?schema=public"

# Weather shown on the dashboard. Coordinates for your location.
WEATHER_LAT=
WEATHER_LON=
WEATHER_PROVIDER=accuweather
ACCUWEATHER_API_KEY=

# Local timezone, used for due dates and the calendar grid.
TZ=UTC

# File ownership for uploaded profile photos. 99:100 matches Unraid's
# nobody:users; use your own host UID/GID elsewhere.
PUID=99
PGID=100
